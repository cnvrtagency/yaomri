{{ 'section-yaomri.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #YaomriBrandStrip-{{ section.id }} {
    --yaomri-brand-strip-background: {{ section.settings.background_color }};
    --yaomri-brand-strip-text: {{ section.settings.text_color }};
    --yaomri-brand-strip-separator: {{ section.settings.separator_color }};
    --yaomri-brand-strip-font-size-desktop: {{ section.settings.font_size_desktop }}px;
    --yaomri-brand-strip-font-size-mobile: {{ section.settings.font_size_mobile }}px;
    --yaomri-brand-strip-padding-desktop: {{ section.settings.padding_y_desktop }}px;
    --yaomri-brand-strip-padding-mobile: {{ section.settings.padding_y_mobile }}px;
    --yaomri-brand-strip-gap-desktop: {{ section.settings.gap_desktop }}px;
    --yaomri-brand-strip-gap-mobile: {{ section.settings.gap_mobile }}px;
    --yaomri-brand-strip-marquee-speed: {{ section.settings.marquee_speed }}s;
    --yaomri-brand-strip-separator-size: {{ section.settings.separator_size }}px;
    --yaomri-brand-strip-separator-spacing: {{ section.settings.separator_spacing }}px;
  }
{%- endstyle -%}

{%- liquid
  assign separator_character = ''
  if section.settings.separator_style == 'pipe'
    assign separator_character = '|'
  elsif section.settings.separator_style == 'dash'
    assign separator_character = '-'
  endif
-%}

<section
  id="YaomriBrandStrip-{{ section.id }}"
  class="yaomri-brand-strip yaomri-brand-strip--{{ section.settings.display_mode }} yaomri-brand-strip--separator-{{ section.settings.separator_style }}"
>
  {%- if section.settings.display_mode == 'marquee' -%}
    <div class="yaomri-brand-strip__marquee" aria-label="Brand statements">
      <div class="yaomri-brand-strip__marquee-track">
        {%- for i in (1..3) -%}
          {%- for block in section.blocks limit: 6 -%}
            {%- if block.settings.text != blank -%}
              <div class="yaomri-brand-strip__item">
                <span class="yaomri-brand-strip__text">{{ block.settings.text | escape }}</span>
                {%- unless section.settings.separator_style == 'none' -%}
                  <span class="yaomri-brand-strip__separator" aria-hidden="true">
                    {%- unless section.settings.separator_style == 'dot' -%}
                      {{- separator_character -}}
                    {%- endunless -%}
                  </span>
                {%- endunless -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        {%- endfor -%}
      </div>
    </div>
  {%- elsif section.settings.display_mode == 'carousel' -%}
    <div class="yaomri-brand-strip__carousel-wrap">
      <button
        class="yaomri-brand-strip__control"
        type="button"
        aria-label="Previous brand statements"
        data-yaomri-brand-prev="{{ section.id }}"
      >
        <span aria-hidden="true">&#8249;</span>
      </button>

      <div
        class="yaomri-brand-strip__carousel no-scrollbar"
        id="YaomriBrandStripTrack-{{ section.id }}"
        role="list"
      >
        {%- for block in section.blocks limit: 6 -%}
          {%- if block.settings.text != blank -%}
            <div class="yaomri-brand-strip__item" role="listitem" {{ block.shopify_attributes }}>
              <span class="yaomri-brand-strip__text">{{ block.settings.text | escape }}</span>
              {%- unless forloop.last or section.settings.separator_style == 'none' -%}
                <span class="yaomri-brand-strip__separator" aria-hidden="true">
                  {%- unless section.settings.separator_style == 'dot' -%}
                    {{- separator_character -}}
                  {%- endunless -%}
                </span>
              {%- endunless -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <button
        class="yaomri-brand-strip__control"
        type="button"
        aria-label="Next brand statements"
        data-yaomri-brand-next="{{ section.id }}"
      >
        <span aria-hidden="true">&#8250;</span>
      </button>
    </div>
  {%- else -%}
    <div class="yaomri-brand-strip__inner yaomri-page-width">
      {%- for block in section.blocks limit: 6 -%}
        {%- if block.settings.text != blank -%}
          <div class="yaomri-brand-strip__item" {{ block.shopify_attributes }}>
            <span class="yaomri-brand-strip__text">{{ block.settings.text | escape }}</span>
            {%- unless forloop.last or section.settings.separator_style == 'none' -%}
              <span class="yaomri-brand-strip__separator" aria-hidden="true">
                {%- unless section.settings.separator_style == 'dot' -%}
                  {{- separator_character -}}
                {%- endunless -%}
              </span>
            {%- endunless -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

{%- if section.settings.display_mode == 'carousel' -%}
  <script>
    (() => {
      const initBrandStripCarousel = () => {
        const section = document.getElementById('YaomriBrandStrip-{{ section.id }}');
        if (!section || section.dataset.yaomriBrandCarouselInit === 'true') return;

        const track = section.querySelector('#YaomriBrandStripTrack-{{ section.id }}');
        const previous = section.querySelector('[data-yaomri-brand-prev="{{ section.id }}"]');
        const next = section.querySelector('[data-yaomri-brand-next="{{ section.id }}"]');
        if (!track || !previous || !next) return;

        const scrollByPage = (direction) => {
          const firstItem = track.querySelector('.yaomri-brand-strip__item');
          const itemWidth = firstItem ? firstItem.getBoundingClientRect().width : 0;
          const scrollAmount = itemWidth > 0 ? Math.max(itemWidth, track.clientWidth * 0.8) : track.clientWidth * 0.8;

          track.scrollBy({
            left: direction * Math.max(scrollAmount, 1),
            behavior: 'smooth'
          });
        };

        previous.addEventListener('click', () => scrollByPage(-1));
        next.addEventListener('click', () => scrollByPage(1));
        section.dataset.yaomriBrandCarouselInit = 'true';
      };

      initBrandStripCarousel();
      document.addEventListener('shopify:section:load', initBrandStripCarousel);
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Brand Strip",
  "tag": "section",
  "class": "section",
  "max_blocks": 6,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "header",
      "content": "Display mode"
    },
    {
      "type": "select",
      "id": "display_mode",
      "label": "Display style",
      "options": [
        {
          "value": "static",
          "label": "Static"
        },
        {
          "value": "marquee",
          "label": "Marquee"
        },
        {
          "value": "carousel",
          "label": "Carousel"
        }
      ],
      "default": "static"
    },
    {
      "type": "header",
      "content": "Marquee settings"
    },
    {
      "type": "range",
      "id": "marquee_speed",
      "min": 10,
      "max": 80,
      "step": 1,
      "unit": "s",
      "label": "Moving marquee speed",
      "default": 28
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size_desktop",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Desktop text size",
      "default": 12
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Mobile text size",
      "default": 11
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_y_desktop",
      "min": 0,
      "max": 48,
      "step": 1,
      "unit": "px",
      "label": "Desktop vertical padding",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_y_mobile",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Mobile vertical padding",
      "default": 16
    },
    {
      "type": "range",
      "id": "gap_desktop",
      "min": 8,
      "max": 80,
      "step": 1,
      "unit": "px",
      "label": "Desktop gap",
      "default": 40
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "min": 8,
      "max": 48,
      "step": 1,
      "unit": "px",
      "label": "Mobile gap",
      "default": 20
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "separator_color",
      "label": "Separator",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Separators"
    },
    {
      "type": "select",
      "id": "separator_style",
      "label": "Separator style",
      "options": [
        {
          "value": "dot",
          "label": "Dot"
        },
        {
          "value": "pipe",
          "label": "Pipe |"
        },
        {
          "value": "dash",
          "label": "Dash -"
        },
        {
          "value": "none",
          "label": "None"
        }
      ],
      "default": "dot"
    },
    {
      "type": "range",
      "id": "separator_size",
      "min": 1,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Separator size",
      "default": 4
    },
    {
      "type": "range",
      "id": "separator_spacing",
      "min": 4,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Separator spacing",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "statement",
      "name": "Statement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Brand statement"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Strip",
      "blocks": [
        {
          "type": "statement",
          "settings": {
            "text": "Sculpted Fits"
          }
        },
        {
          "type": "statement",
          "settings": {
            "text": "Premium Swimwear"
          }
        },
        {
          "type": "statement",
          "settings": {
            "text": "Resort-Ready Styling"
          }
        },
        {
          "type": "statement",
          "settings": {
            "text": "Designed to Turn Heads"
          }
        }
      ]
    }
  ]
}
{% endschema %}
