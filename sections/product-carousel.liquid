{{ 'section-yaomri.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign mobile_gap_rem = section.settings.card_gap_mobile | divided_by: 10.0
  assign desktop_gap_rem = section.settings.card_gap_desktop | divided_by: 10.0
  assign mobile_gap_total = section.settings.products_per_row_mobile | minus: 1 | times: mobile_gap_rem
  assign tablet_gap_total = section.settings.products_per_row_tablet | minus: 1 | times: desktop_gap_rem
  assign desktop_gap_total = section.settings.products_per_row_desktop | minus: 1 | times: desktop_gap_rem
  assign title_weight = 600
  assign price_weight = 600
  assign title_transform = 'uppercase'
  assign category_transform = 'none'
  assign image_aspect_ratio = '4 / 5'

  case section.settings.product_title_weight
    when 'regular'
      assign title_weight = 400
    when 'medium'
      assign title_weight = 500
    when 'bold'
      assign title_weight = 700
  endcase

  case section.settings.price_weight
    when 'regular'
      assign price_weight = 400
    when 'medium'
      assign price_weight = 500
    when 'bold'
      assign price_weight = 700
  endcase

  case section.settings.product_title_case
    when 'default'
      assign title_transform = 'none'
    when 'lowercase'
      assign title_transform = 'lowercase'
    when 'capitalize'
      assign title_transform = 'capitalize'
  endcase

  case section.settings.category_label_case
    when 'uppercase'
      assign category_transform = 'uppercase'
    when 'lowercase'
      assign category_transform = 'lowercase'
    when 'capitalize'
      assign category_transform = 'capitalize'
  endcase

  case section.settings.image_aspect_ratio
    when 'square'
      assign image_aspect_ratio = '1 / 1'
    when 'portrait_3_4'
      assign image_aspect_ratio = '3 / 4'
    when 'landscape_4_3'
      assign image_aspect_ratio = '4 / 3'
  endcase
-%}

{%- style -%}
  #YaomriProductCarousel-{{ section.id }} {
    --yaomri-product-carousel-padding-top: {{ section.settings.padding_top }}px;
    --yaomri-product-carousel-padding-bottom: {{ section.settings.padding_bottom }}px;
    --yaomri-products-desktop: {{ section.settings.products_per_row_desktop }};
    --yaomri-products-tablet: {{ section.settings.products_per_row_tablet }};
    --yaomri-products-mobile: {{ section.settings.products_per_row_mobile }};
    --yaomri-product-carousel-gap-desktop: {{ section.settings.card_gap_desktop | divided_by: 10.0 }}rem;
    --yaomri-product-carousel-gap-mobile: {{ section.settings.card_gap_mobile | divided_by: 10.0 }}rem;
    --yaomri-product-card-width-desktop: calc((100% - {{ desktop_gap_total }}rem) / {{ section.settings.products_per_row_desktop }});
    --yaomri-product-card-width-tablet: calc((100% - {{ tablet_gap_total }}rem) / {{ section.settings.products_per_row_tablet }});
    --yaomri-product-card-width-mobile: calc((100% - {{ mobile_gap_total }}rem) / {{ section.settings.products_per_row_mobile }});
    --product-title-size: {{ section.settings.product_title_size | divided_by: 10.0 }}rem;
    --product-title-weight: {{ title_weight }};
    --product-title-style: {{ section.settings.product_title_style }};
    --product-title-transform: {{ title_transform }};
    --product-title-color: {{ section.settings.product_title_color }};
    --category-size: {{ section.settings.category_label_size | divided_by: 10.0 }}rem;
    --category-color: {{ section.settings.category_label_color }};
    --category-transform: {{ category_transform }};
    --price-size: {{ section.settings.price_size | divided_by: 10.0 }}rem;
    --price-weight: {{ price_weight }};
    --price-color: {{ section.settings.price_color }};
    --price-style: {{ section.settings.price_style }};
    --product-image-aspect-ratio: {{ image_aspect_ratio }};
    --product-image-radius: {{ section.settings.product_image_radius }}px;
    --product-badge-size: {{ section.settings.badge_text_size | divided_by: 10.0 }}rem;
    --product-badge-bg: {{ section.settings.badge_background }};
    --product-badge-text: {{ section.settings.badge_text_color }};
    --product-badge-border: {{ section.settings.badge_border_color }};
  }
{%- endstyle -%}

{%- liquid
  assign display_count_label = ''

  if section.settings.count_mode == 'automatic_count'
    assign display_count_label = section.settings.count_label
    if section.settings.collection != blank
      assign product_count = section.settings.collection.all_products_count
      assign display_count_label = product_count | append: ' pieces'
    endif
  elsif section.settings.count_mode == 'custom_label'
    assign display_count_label = section.settings.count_label
  endif

  if display_count_label == blank and section.settings.count_mode == 'automatic_count' and section.settings.collection == blank
    assign display_count_label = ''
  endif

  if section.settings.count_mode == 'hidden'
    assign display_count_label = ''
  endif

  if section.settings.count_mode == blank
    assign display_count_label = section.settings.count_label | default: '24 pieces'
  elsif section.settings.count_mode == 'automatic' and section.settings.collection != blank
    assign product_count = section.settings.collection.all_products_count
    assign display_count_label = product_count | append: ' pieces'
  elsif section.settings.count_mode == 'manual'
    assign display_count_label = section.settings.count_label
  endif
-%}

<section id="YaomriProductCarousel-{{ section.id }}" class="yaomri-product-carousel">
  <div class="yaomri-product-carousel__inner yaomri-page-width">
    <div class="yaomri-product-carousel__header">
      <div class="yaomri-product-carousel__title-wrap">
        {%- if section.settings.title != blank -%}
          <h2 class="yaomri-product-carousel__title">{{ section.settings.title | escape }}</h2>
        {%- endif -%}

        {%- if display_count_label != blank -%}
          <span class="yaomri-product-carousel__count">{{ display_count_label | escape }}</span>
        {%- endif -%}
      </div>

      {%- if section.settings.show_arrows -%}
        <div class="yaomri-product-carousel__arrows">
          <button
            class="yaomri-product-carousel__arrow"
            type="button"
            aria-label="Previous products"
            data-yaomri-carousel-prev="{{ section.id }}"
          >
            <span aria-hidden="true">&#8249;</span>
          </button>
          <button
            class="yaomri-product-carousel__arrow"
            type="button"
            aria-label="Next products"
            data-yaomri-carousel-next="{{ section.id }}"
          >
            <span aria-hidden="true">&#8250;</span>
          </button>
        </div>
      {%- endif -%}
    </div>

    <div
      class="yaomri-product-carousel__track no-scrollbar"
      id="YaomriProductCarouselTrack-{{ section.id }}"
      role="list"
    >
      {%- if section.settings.collection != blank and section.settings.collection.products.size > 0 -%}
        {%- for product in section.settings.collection.products limit: section.settings.product_limit -%}
          <article class="yaomri-product-carousel__card" role="listitem">
            <a class="yaomri-product-carousel__media-link" href="{{ product.url }}" aria-label="{{ product.title | escape }}">
              <div class="yaomri-product-carousel__media">
                {%- if product.featured_image != blank -%}
                  {%- assign image_height = product.featured_image.width | divided_by: product.featured_image.aspect_ratio -%}
                  {{
                    product.featured_image
                    | image_url: width: 900
                    | image_tag:
                      width: product.featured_image.width,
                      height: image_height,
                      class: 'yaomri-product-carousel__image',
                      sizes: '(min-width: 990px) 20vw, (min-width: 750px) 25vw, 50vw',
                      widths: '180, 240, 320, 420, 550, 720, 900',
                      loading: 'lazy'
                  }}
                {%- else -%}
                  <div
                    class="yaomri-product-carousel__placeholder placeholder-img"
                    data-label="{{ product.title | escape }}"
                  ></div>
                {%- endif -%}

                {%- if section.settings.show_new_tag and product.tags contains 'New' -%}
                  <span class="yaomri-product-carousel__tag">New</span>
                {%- endif -%}
              </div>
            </a>

            {%- if section.settings.show_wishlist -%}
              <button
                class="yaomri-product-carousel__wishlist"
                type="button"
                aria-label="Add {{ product.title | escape }} to wishlist"
              >
                <span aria-hidden="true">&#9825;</span>
              </button>
            {%- endif -%}

            <div class="yaomri-product-carousel__info">
              {%- if section.settings.show_product_title -%}
                <h3 class="yaomri-product-carousel__product-title">
                  <a href="{{ product.url }}">{{ product.title | escape }}</a>
                </h3>
              {%- endif -%}
              {%- if section.settings.show_category_label and section.settings.category_label != blank -%}
                <p class="yaomri-product-carousel__category">{{ section.settings.category_label | escape }}</p>
              {%- endif -%}
              {%- if section.settings.show_price -%}
                <p class="yaomri-product-carousel__price">{{ product.price | money }}</p>
              {%- endif -%}
            </div>
          </article>
        {%- endfor -%}
      {%- else -%}
        {%- liquid
          assign placeholder_names = 'Solara Bikini Set|Amara One Piece|Capri Cover-Up|Isla Triangle Bikini|Mira Wrap One Piece' | split: '|'
          assign placeholder_prices = 'AED 720|AED 890|AED 1,120|AED 680|AED 940' | split: '|'
        -%}

        {%- for placeholder_name in placeholder_names -%}
          <article class="yaomri-product-carousel__card" role="listitem">
            <div class="yaomri-product-carousel__media">
              <div
                class="yaomri-product-carousel__placeholder placeholder-img"
                data-label="{{ placeholder_name | escape }}"
              ></div>
            </div>

            {%- if section.settings.show_wishlist -%}
              <button
                class="yaomri-product-carousel__wishlist"
                type="button"
                aria-label="Add {{ placeholder_name | escape }} to wishlist"
              >
                <span aria-hidden="true">&#9825;</span>
              </button>
            {%- endif -%}

            <div class="yaomri-product-carousel__info">
              {%- if section.settings.show_product_title -%}
                <h3 class="yaomri-product-carousel__product-title">
                  <a role="link" aria-disabled="true">{{ placeholder_name | escape }}</a>
                </h3>
              {%- endif -%}
              {%- if section.settings.show_category_label and section.settings.category_label != blank -%}
                <p class="yaomri-product-carousel__category">{{ section.settings.category_label | escape }}</p>
              {%- endif -%}
              {%- if section.settings.show_price -%}
                <p class="yaomri-product-carousel__price">{{ placeholder_prices[forloop.index0] }}</p>
              {%- endif -%}
            </div>
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{%- if section.settings.show_arrows -%}
  <script>
    (() => {
      const section = document.getElementById('YaomriProductCarousel-{{ section.id }}');
      if (!section) return;

      const track = section.querySelector('#YaomriProductCarouselTrack-{{ section.id }}');
      const previous = section.querySelector('[data-yaomri-carousel-prev="{{ section.id }}"]');
      const next = section.querySelector('[data-yaomri-carousel-next="{{ section.id }}"]');
      if (!track || !previous || !next) return;

      const scrollByPage = (direction) => {
        const firstCard = track.querySelector('.yaomri-product-carousel__card');
        const cardWidth = firstCard ? firstCard.getBoundingClientRect().width : 0;
        const scrollAmount = cardWidth > 0 ? Math.max(cardWidth, track.clientWidth - cardWidth) : track.clientWidth * 0.9;

        track.scrollBy({
          left: direction * Math.max(scrollAmount, 1),
          behavior: 'smooth'
        });
      };

      previous.addEventListener('click', () => scrollByPage(-1));
      next.addEventListener('click', () => scrollByPage(1));
    })();
  </script>
{%- endif -%}

{% schema %}
