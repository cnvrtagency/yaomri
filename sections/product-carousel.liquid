    {
      "type": "text",
      "id": "title",
      "label": "Section title",
      "default": "New In - Swimwear"
    },
    {
      "type": "header",
      "content": "Collection & product count"
    },
    {
      "type": "text",
      "id": "count_label",
      "label": "Custom count text",
      "default": "24 pieces"
    },
    {
