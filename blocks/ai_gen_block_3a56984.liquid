{% doc %}
  @prompt
    2 column section, 1 with video, 1 for html - no controls on the video

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-html-section-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.column_gap }}px;
    padding: {{ block.settings.section_padding }}px;
    background-color: {{ block.settings.background_color }};
    align-items: {{ block.settings.vertical_alignment }};
  }

  .ai-video-column-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    border-radius: {{ block.settings.video_border_radius }}px;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-video-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-video-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 300px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-video-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
    opacity: 0.5;
  }

  .ai-video-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-html-column-{{ ai_gen_id }} {
    padding: {{ block.settings.html_padding }}px;
    background-color: {{ block.settings.html_background_color }};
    border-radius: {{ block.settings.html_border_radius }}px;
    color: {{ block.settings.html_text_color }};
  }

  .ai-html-content-{{ ai_gen_id }} {
    font-size: {{ block.settings.html_font_size }}px;
    line-height: 1.6;
  }

  .ai-html-content-{{ ai_gen_id }} h1,
  .ai-html-content-{{ ai_gen_id }} h2,
  .ai-html-content-{{ ai_gen_id }} h3,
  .ai-html-content-{{ ai_gen_id }} h4,
  .ai-html-content-{{ ai_gen_id }} h5,
  .ai-html-content-{{ ai_gen_id }} h6 {
    color: {{ block.settings.html_heading_color }};
    margin-top: 0;
    margin-bottom: 16px;
  }

  .ai-html-content-{{ ai_gen_id }} p {
    margin-bottom: 16px;
  }

  .ai-html-content-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-html-placeholder-{{ ai_gen_id }} {
    padding: 40px 20px;
    text-align: center;
    color: #999;
    font-style: italic;
    border: 2px dashed #ddd;
    border-radius: 8px;
  }

  @media screen and (max-width: 768px) {
    .ai-video-html-section-{{ ai_gen_id }} {
      grid-template-columns: 1fr;gap: {{ block.settings.column_gap | divided_by: 2 }}px;
    }

    {% if block.settings.mobile_order == 'html_first' %}
      .ai-video-column-{{ ai_gen_id }} {
        order: 2;
      }
      .ai-html-column-{{ ai_gen_id }} {
        order: 1;
      }
    {% endif %}
  }
{% endstyle %}

<div class="ai-video-html-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-video-column-{{ ai_gen_id }}">
    <div class="ai-video-wrapper-{{ ai_gen_id }}">
      {% if block.settings.video %}
        <video
          class="ai-video-{{ ai_gen_id }}"
          {% if block.settings.autoplay %}autoplay{% endif %}
          {% if block.settings.loop %}loop{% endif %}
          {% if block.settings.muted %}muted{% endif %}
          playsinline
          preload="metadata"
        >
          <source src="{{ block.settings.video }}" type="video/mp4">
          Your browser does not support the video tag.
        </video>
      {% else %}
        <div class="ai-video-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-video-empty-state-{{ ai_gen_id }}">
            Next, add a video
          </div>
        </div>
      {% endif %}
    </div>
  </div>

  <div class="ai-html-column-{{ ai_gen_id }}">
    {% if block.settings.html_content != blank %}
      <div class="ai-html-content-{{ ai_gen_id }}">
        {{ block.settings.html_content }}
      </div>
    {% else %}
      <div class="ai-html-placeholder-{{ ai_gen_id }}">
        Next, add your HTML content
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Video and HTML columns",
  "settings": [
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "url",
      "id": "video",
      "label": "Video file"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay video",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop video",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "muted",
      "label": "Mute video",
      "default": true
    },
    {
      "type": "range",
      "id": "video_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Video border radius",
      "default": 8
    },
    {
      "type": "header",
      "content": "HTML content"
    },
    {
      "type": "html",
      "id": "html_content",
      "label": "HTML content"
    },
    {
      "type": "range",
      "id": "html_padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Content padding",
      "default": 32
    },
    {
      "type": "range",
      "id": "html_font_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Font size",
      "default": 16
    },
    {
      "type": "color",
      "id": "html_background_color",
      "label": "Content background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "html_text_color",
      "label": "Text color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "html_heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "html_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Content border radius",
      "default": 8
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "Vertical alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Top"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Bottom"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "column_gap",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Column gap",
      "default": 40
    },
    {
      "type": "range",
      "id": "section_padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Section padding",
      "default": 40
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#f8f8f8"
    },
    {
      "type": "select",
      "id": "mobile_order",
      "label": "Mobile column order",
      "options": [
        {
          "value": "video_first",
          "label": "Video first"
        },
        {
          "value": "html_first",
          "label": "HTML first"
        }
      ],
      "default": "video_first"
    }
  ],
  "presets": [
    {
      "name": "Video and HTML columns"
    }
  ],
  "tag": null
}
{% endschema %}