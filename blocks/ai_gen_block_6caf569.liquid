{% doc %}
  @prompt
    A section for a video, but with the option to choose a different video for mobile view., maximum with should go to 1600, i would like the optino for the section to be full width (span the entire screen, i dont want any controls, just more of a bacgrkound video

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-section-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
  }

  .ai-video-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    {% if block.settings.full_width %}
      max-width: none;
      padding: 0;
    {% else %}
      max-width: {{ block.settings.max_width }}px;
      margin: 0 auto;
      padding: 0 20px;
    {% endif %}
  }

  .ai-video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 0;
    padding-bottom: {{ block.settings.aspect_ratio }}%;
    background-color: #000;
    {% unless block.settings.full_width %}
      border-radius: {{ block.settings.border_radius }}px;
    {% endunless %}
    overflow: hidden;
  }

  .ai-video-element-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-video-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
    color: #666;
  }

  .ai-video-placeholder-{{ ai_gen_id }} svg {
    width: 80px;
    height: 80px;
    opacity: 0.5;
  }

  .ai-video-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 6px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-video-mobile-{{ ai_gen_id }} {
    display: none;
  }

  .ai-video-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, {{ block.settings.overlay_opacity | divided_by: 100.0 }});
    z-index: 1;
  }

  .ai-video-content-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    color: {{ block.settings.text_color }};
    z-index: 2;
    max-width: 90%;}

  .ai-video-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 600;
    margin: 0 0 16px;
    line-height: 1.2;
  }

  .ai-video-subtext-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    margin: 0 0 24px;
    line-height: 1.4;
  }

  .ai-video-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 24px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 500;
    transition: background-color 0.3s ease;
  }

  .ai-video-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-video-container-{{ ai_gen_id }} {
      {% unless block.settings.full_width %}
        padding: 0 15px;
      {% endunless %}
    }

    .ai-video-desktop-{{ ai_gen_id }} {
      display: none;
    }

    .ai-video-mobile-{{ ai_gen_id }} {
      display: block;
    }

    .ai-video-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-video-subtext-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }

    .ai-video-content-{{ ai_gen_id }} {
      max-width: 95%;
    }
  }
{% endstyle %}

<div
  class="ai-video-section-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-video-container-{{ ai_gen_id }}">
    <div class="ai-video-wrapper-{{ ai_gen_id }}">
      {% if block.settings.video_desktop %}
        <video
          class="ai-video-element-{{ ai_gen_id }} ai-video-desktop-{{ ai_gen_id }}"
          autoplay
          loop
          muted
          playsinline
          preload="auto"
        >
          <source src="{{ block.settings.video_desktop.sources[1].url }}" type="{{ block.settings.video_desktop.sources[1].mime_type }}">
          Your browser does not support the video tag.
        </video>
      {% endif %}

      {% if block.settings.video_mobile %}
        <video
          class="ai-video-element-{{ ai_gen_id }} ai-video-mobile-{{ ai_gen_id }}"
          autoplay
          loop
          muted
          playsinline
          preload="auto"
        >
          <source src="{{ block.settings.video_mobile.sources[1].url }}" type="{{ block.settings.video_mobile.sources[1].mime_type }}">
          Your browser does not support the video tag.
        </video>
      {% elsif block.settings.video_desktop %}
        <video
          class="ai-video-element-{{ ai_gen_id }} ai-video-mobile-{{ ai_gen_id }}"
          autoplay
          loop
          muted
          playsinline
          preload="auto"
        >
          <source src="{{ block.settings.video_desktop.sources[1].url }}" type="{{ block.settings.video_desktop.sources[1].mime_type }}">
          Your browser does not support the video tag.
        </video>
      {% endif %}

      {% unless block.settings.video_desktop %}
        <div class="ai-video-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-video-empty-state-{{ ai_gen_id }}">
            Add a video for desktop view
          </div>
        </div>
      {% endunless %}

      {% if block.settings.show_overlay %}
        <div class="ai-video-overlay-{{ ai_gen_id }}"></div>
      {% endif %}

      {% if block.settings.heading != blank or block.settings.subtext != blank or block.settings.button_text != blank %}
        <div class="ai-video-content-{{ ai_gen_id }}">
          {% if block.settings.heading != blank %}
            <h2 class="ai-video-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
          {% endif %}

          {% if block.settings.subtext != blank %}
            <div class="ai-video-subtext-{{ ai_gen_id }}">{{ block.settings.subtext }}</div>
          {% endif %}

          {% if block.settings.button_text != blank and block.settings.button_link != blank %}
            <a href="{{ block.settings.button_link }}" class="ai-video-button-{{ ai_gen_id }}">
              {{ block.settings.button_text }}
            </a>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Background video",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Video files"
    },
    {
      "type": "video",
      "id": "video_desktop",
      "label": "Desktop video"
    },
    {
      "type": "video",
      "id": "video_mobile",
      "label": "Mobile video"
    },
    {
      "type": "paragraph",
      "content": "If no mobile video is selected, the desktop video will be used on mobile devices. Videos will autoplay, loop, and be muted by default."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Subtext"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Show overlay",
      "default": true
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 30
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": false
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Aspect ratio",
      "options": [
        {
          "value": "56.25",
          "label": "16:9"
        },
        {
          "value": "75",
          "label": "4:3"
        },
        {
          "value": "66.66",
          "label": "3:2"
        },
        {
          "value": "100",
          "label": "1:1"
        },
        {
          "value": "125",
          "label": "4:5"
        },
        {
          "value": "40",
          "label": "21:9"
        }
      ],
      "default": "56.25"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 400,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "label": "Maximum width",
      "default": 1200,
      "info": "Only applies when full width is disabled"
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 0,
      "info": "Only applies when full width is disabled"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button hover color",
      "default": "#f0f0f0"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 48
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Text size",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Button border radius",
      "default": 4
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Bottom padding",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Background video"
    }
  ]
}
{% endschema %}