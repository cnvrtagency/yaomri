{% doc %}
  @prompt
    2 column section, left side is image  the right side is a custom liquid box - options to customise everything
    
    , options to fully customise on mobiel devices too, e.g padding 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-two-column-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: {{ block.settings.column_gap }}px;
    align-items: {{ block.settings.vertical_alignment }};
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
  }

  .ai-two-column__image-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.image_width }}%;
    max-width: {{ block.settings.image_width }}%;
  }

  .ai-two-column__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-two-column__image-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-two-column__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-two-column__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-two-column__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-two-column__liquid-{{ ai_gen_id }} {
    flex: 0 0 calc({{ 100 | minus: block.settings.image_width }}% - {{ block.settings.column_gap }}px);
    max-width: calc({{ 100 | minus: block.settings.image_width }}% - {{ block.settings.column_gap }}px);
    background-color: {{ block.settings.liquid_background_color }};
    padding: {{ block.settings.liquid_padding }}px;
    border-radius: {{ block.settings.liquid_border_radius }}px;
    border: {{ block.settings.liquid_border_width }}px solid {{ block.settings.liquid_border_color }};
  }

  .ai-two-column__liquid-content-{{ ai_gen_id }} {
    color: {{ block.settings.liquid_text_color }};
    font-size: {{ block.settings.liquid_font_size }}px;
    line-height: 1.6;
  }

  @media screen and (max-width: 749px) {
    .ai-two-column-{{ ai_gen_id }} {
      flex-direction: {{ block.settings.mobile_layout }};
      gap: {{ block.settings.mobile_gap }}px;
      padding: {{ block.settings.mobile_padding_top }}px {{ block.settings.mobile_padding_horizontal }}px {{ block.settings.mobile_padding_bottom }}px;
    }

    .ai-two-column__image-{{ ai_gen_id }},
    .ai-two-column__liquid-{{ ai_gen_id }} {
      flex: 0 0 100%;
      max-width: 100%;
    }

    .ai-two-column__image-wrapper-{{ ai_gen_id }} {
      border-radius: {{ block.settings.mobile_image_border_radius }}px;
    }

    .ai-two-column__image-placeholder-{{ ai_gen_id }} {
      aspect-ratio: {{ block.settings.mobile_image_aspect_ratio }};
      border-radius: {{ block.settings.mobile_image_border_radius }}px;
    }

    .ai-two-column__liquid-{{ ai_gen_id }} {
      padding: {{ block.settings.mobile_liquid_padding }}px;
      border-radius: {{ block.settings.mobile_liquid_border_radius }}px;
      border-width: {{ block.settings.mobile_liquid_border_width }}px;
    }

    .ai-two-column__liquid-content-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_liquid_font_size }}px;
    }
  }
{% endstyle %}

<div
  class="ai-two-column-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-two-column__image-{{ ai_gen_id }}">
    <div class="ai-two-column__image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 2000 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
        >
      {% else %}
        <div class="ai-two-column__image-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-two-column__empty-state-{{ ai_gen_id }}">
            Add an image
          </div>
        </div>
      {% endif %}
    </div>
  </div>

  <div class="ai-two-column__liquid-{{ ai_gen_id }}">
    <div class="ai-two-column__liquid-content-{{ ai_gen_id }}">
      {{ block.settings.custom_liquid }}
    </div>
  </div>
</div>

