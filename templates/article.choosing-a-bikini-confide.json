        "custom_text_xePENV": {
          "type": "custom_text",
          "settings": {
            "text": "Bringing It All Together",
            "remove_br_tag": false,
            "tag": "h2",
            "fontf": "inherit",
            "text_cl": "#000000",
            "text_fs": 18,
            "text_lh": 0,
            "text_fw": 500,
            "text_ls": 1.5,
            "font_italic": false,
            "text_shadow": false,
            "text_mgb": 15,
