        "custom_text_RUGKg8": {
          "type": "custom_text",
          "settings": {
            "text": "Choosing The Right Bikini",
            "remove_br_tag": false,
            "tag": "h2",
            "fontf": "inherit",
            "text_cl": "#000000",
            "text_fs": 18,
            "text_lh": 0,
            "text_fw": 500,
            "text_ls": 1.5,
            "font_italic": false,
            "text_shadow": false,
            "text_mgb": 15,
            "hidden_mobile": false,
            "text_fs_mb": 16,
            "text_lh_mb": 21,
            "text_ls_mb": 1.5,
            "text_mgb_mobile": 10
          }
        },
        "custom_text_MakfTh": {
          "type": "custom_text",
          "settings": {
            "text": "Choosing a <a href=\"/collections/bikinis\" title=\"Luxury bikinis\">bikini</a> that encourages confidence is rarely just about style. Confidence in swimwear comes from how a bikini fits, how it supports the body, and how it feels once you are actually wearing it outside the mirror. A bikini should feel secure, intentional, and comfortable enough that you are not constantly adjusting it or thinking about how it looks from every angle.\n<br><br>\nMany women assume that discomfort in a bikini is a personal issue, when in reality it is often a design problem. Poor construction, low quality fabric, and weak support can make even the most visually appealing bikini feel wrong once it is on. <a href=\"/collections/swimwear\" title=\"Luxury swimwear\">Luxury swimwear</a> approaches bikinis differently, prioritising fit, fabric performance, and structure so the bikini works with the body rather than against it.\n\nConfidence is not about following rules or trends. It is about choosing a bikini that allows you to relax into wearing it, whether you are by the pool, at the beach, or spending a full day in the sun. When a bikini fits properly and feels considered in its design, confidence follows naturally.",
            "remove_br_tag": false,
            "tag": "p",
            "fontf": "inherit",
            "text_cl": "#000000",
            "text_fs": 16,
            "text_lh": 24,
            "text_fw": 300,
            "text_ls": 0,
            "font_italic": false,
            "text_shadow": false,
            "text_mgb": 15,
            "hidden_mobile": false,
            "text_fs_mb": 16,
            "text_lh_mb": 24,
            "text_ls_mb": 0,
            "text_mgb_mobile": 10
          }
        }
