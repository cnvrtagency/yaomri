      "name": "Custom Liquid",
      "settings": {
        "custom_liquid": "<div class=\"bottom-content\">\n  {{ collection.description | split: '<!-- split -->' | last }}\n</div>\n\n<style>\n.bottom-content {\n  margin: 0 auto;\n  padding: 0px 0px 0px 0px;\n  font-weight: 300;\n  font-size: 14px;\n  line-height: 25px;\n  color: rgb(120, 120, 120);\n}\n\n/* Headings */\n.bottom-content h2 {\n  font-size: 18px;\n  line-height: 1.4;\n  font-weight: 600;\n  color: #111;\n  margin: 30px 0 20px;\n  text-transform: uppercase;\n  border-top: 0px solid #eee;\n  border-bottom: 0px solid #eee;\n  padding: 0px 0;\n  letter-spacing: 1.5px;\n}\n\n.bottom-content h3 {\n  font-size: 14px;\n  text-transform: uppercase;\n  line-height: 1.5;\n  font-weight: 600;\n  margin: 20px 0 12px;\n  color: #333;\n  letter-spacing: 1.5px;\n}\n\n/* Paragraphs just inherit base */\n.bottom-content p {\n  margin: 0 0 20px;\n  color: black;\n}\n\n/* Mobile */\n@media (max-width: 600px) {\n  .bottom-content {\n    padding: 0 10px;\n    font-size: 14px;\n    line-height: 22px;\n  }\n\n  .bottom-content h2 {\n    font-size: 14px;\n    margin: 0px 0px 0px 0px;\n    padding: 0 20px 15px 0;\n  }\n\n  .bottom-content h3 {\n    font-size: 13px;\n    margin: 15px 0 10px;\n    max-width: 250px;\n  }\n}\n</style>",
