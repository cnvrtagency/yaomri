      "settings": {
        "custom_liquid": "<style>\n.logo-carousel {\n  overflow: hidden;\n  position: relative;\n  width: 100%;\n  background: transparent;\n\n  /* Premium fade edges */\n  mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);\n  -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);\n}\n\n.logo-track {\n  display: flex;\n  width: max-content;\n  animation: scroll 25s linear infinite;\n}\n\n.logo-item {\n  flex: 0 0 auto;\n  padding: 0 30px;\n  display: flex;\n  align-items: center;\n}\n\n.logo-item img {\n  height: 50px; /* 👈 key change */\n  width: auto;\n  object-fit: contain;\n  opacity: 0.8;\n  transition: opacity 0.3s ease;\n}\n\n.logo-item img:hover {\n  opacity: 1;\n}\n\n/* Seamless loop */\n@keyframes scroll {\n  from {\n    transform: translateX(0);\n  }\n  to {\n    transform: translateX(-50%);\n  }\n}\n\n/* Pause on hover */\n.logo-carousel:hover .logo-track {\n  animation-play-state: paused;\n}\n\n/* Mobile */\n@media (max-width: 768px) {\n  .logo-item {\n    padding: 0 20px;\n  }\n\n  .logo-item img {\n    height: 36px;\n  }\n}\n</style>\n\n<div class=\"logo-carousel\">\n  <div class=\"logo-track\">\n\n    {% assign logos = \n      \"https://cdn.shopify.com/s/files/1/1545/8313/files/travel-magazine-swimwear.png?v=1759913168|\n       https://cdn.shopify.com/s/files/1/1545/8313/files/cosmopolitan-middle-east-magazine.png?v=1759913168|\n       https://cdn.shopify.com/s/files/1/1545/8313/files/luxury_lifestyle_magazine.png?v=1759913167|\n       https://cdn.shopify.com/s/files/1/1545/8313/files/grazia-magazine.png?v=1759913167\" \n       | split: \"|\" %}\n\n    <!-- Duplicate for infinite loop -->\n    {% for i in (1..2) %}\n      {% for logo in logos %}\n        <div class=\"logo-item\">\n          <img src=\"{{ logo | strip }}\" alt=\"Featured In\">\n        </div>\n      {% endfor %}\n    {% endfor %}\n\n  </div>\n</div>",
        "layout": "t4s-container-fluid",
