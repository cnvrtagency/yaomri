            "custom_liquid": "{% comment %}\n  Product Media Slider (Images + Videos)\n  Metafield: custom.product_videos\n  Type: List of files (Videos + Images)\n{% endcomment %}\n\n{% assign media_field = product.metafields.custom.product_videos %}\n{% assign media_items = media_field.value | default: blank %}\n\n{% if media_items != blank %}\n<div id=\"VideoSlider-CUSTOM\" class=\"video-slider-section\">\n  <div class=\"video-slider-container\">\n    <div class=\"video-slider-track\">\n\n      {% for item in media_items %}\n        <div class=\"video-card\">\n\n          {%- if item.media_type == 'video' -%}\n            {{ item | video_tag:\n              class: \"video-card__media\",\n              autoplay: true,\n              loop: true,\n              muted: true,\n              playsinline: true,\n              preload: \"metadata\"\n            }}\n\n          {%- elsif item.media_type == 'image' -%}\n            {{ item\n              | image_url: width: 800\n              | image_tag:\n                class: \"video-card__media\",\n                loading: \"lazy\"\n            }}\n          {%- endif -%}\n\n        </div>\n      {% endfor %}\n\n    </div>\n  </div>\n</div>\n\n<style>\n#VideoSlider-CUSTOM{\n  --card-width-desktop:170px;\n  --card-width-tablet:150px;\n  --card-ratio:1.45;\n  --gap:14px;\n  width:100%;\n  margin:-10px 0;\n  overflow:hidden;\n}\n#VideoSlider-CUSTOM .video-slider-container{max-width:1400px;margin:0 auto;}\n#VideoSlider-CUSTOM .video-slider-track{\n  display:flex;\n  gap:var(--gap);\n  overflow-x:auto;\n  scroll-snap-type:x mandatory;\n  -webkit-overflow-scrolling:touch;\n  padding:6px 0;\n  scrollbar-width:none;\n}\n#VideoSlider-CUSTOM .video-slider-track::-webkit-scrollbar{display:none;}\n#VideoSlider-CUSTOM .video-card{\n  flex:0 0 var(--card-width-desktop);\n  width:var(--card-width-desktop);\n  height:calc(var(--card-width-desktop) * var(--card-ratio));\n  background:#000;\n  border-radius:10px;\n  overflow:hidden;\n  scroll-snap-align:start;\n}\n#VideoSlider-CUSTOM .video-card__media{\n  width:100%;\n  height:100%;\n  object-fit:cover;\n  display:block;\n}\n@media (max-width:1024px){\n  #VideoSlider-CUSTOM .video-card{\n    flex:0 0 var(--card-width-tablet);\n    width:var(--card-width-tablet);\n    height:calc(var(--card-width-tablet) * var(--card-ratio));\n  }\n}\n@media (max-width:767px){\n  #VideoSlider-CUSTOM{--gap:10px;}\n  #VideoSlider-CUSTOM .video-card{\n    --mobile-width:calc((100vw - 24px - (2 * var(--gap))) / 3);\n    flex:0 0 var(--mobile-width);\n    width:var(--mobile-width);\n    height:calc(var(--mobile-width) * var(--card-ratio));\n  }\n}\n</style>\n{% endif %}"
