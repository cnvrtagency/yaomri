        "use_cus_css": true,
        "code_cus_css": "/* --- SECTION TITLES --- */\nh3.t4s-section-title.t4s-title {\n  font-size: 18px;\n  line-height: 1.4;\n  font-weight: 600;\n  color: #111;\n  margin: 30px 0 20px;\n  text-transform: uppercase;\n  border: none;\n  padding: 0;\n  letter-spacing: 1.5px;\n}\n\n/* --- ACCORDION WRAPPER RESET --- */\n.t4s-tabs.t4s-type-accordion {\n  text-align: left !important;\n  padding: 0 !important;\n  margin: 0 !important;\n}\n\n/* --- INDIVIDUAL ITEMS --- */\n.t4s-tab-wrapper {\n  text-align: left !important;\n  margin: 0 !important;\n  padding: 20px 0 !important; /* roomy above, moderate below */\n  border-bottom: 1px solid #e0e0e0;\n}\n\n/* optional top border for symmetry */\n.t4s-tab-wrapper:first-child {\n  border-top: 1px solid #e0e0e0;\n}\n\n/* --- ACCORDION TITLE (QUESTION) --- */\n.t4s-accor-title {\n  display: flex !important;\n  justify-content: flex-start !important;\n  align-items: center !important;\n  width: 100%;\n  text-align: left !important;\n  font-size: 13px;\n  line-height: 1.4;\n  font-weight: 600 !important;\n  color: #111;\n  text-transform: uppercase;\n  letter-spacing: 1px;\n  margin: 0;\n  padding: 15px 40px 16px 0; /* balanced spacing + right gap for icon */\n  background: none;\n  border: none;\n  text-decoration: none;\n  cursor: pointer;\n  position: relative;\n}\n\n/* --- TEXT WRAPPER --- */\n.t4s-accor-text {\n  display: flex !important;\n  align-items: center !important;\n  justify-content: flex-start !important;\n  flex: 1 !important;\n  flex-wrap: wrap !important;\n  text-align: left !important;\n  padding: 0 !important;\n  margin: 0 !important;\n}\n\n/* --- INNER SPANS --- */\n.t4s-accor-text span,\n.t4s-accor-title span[itemprop=\"name\"] {\n  display: inline-flex !important;\n  align-items: center !important;\n  text-align: left !important;\n  padding: 0 !important;\n  margin: 0 !important;\n  line-height: 1.6 !important;\n}\n\n/* --- CUSTOM + / – ICON (FLUSH TO EDGE) --- */\n.t4s-accor-title::after {\n  content: \"＋\";\n  display: inline-flex !important;\n  align-items: center !important;\n  justify-content: center !important;\n  font-size: 18px;\n  color: #888;\n  line-height: 1 !important;\n  height: 1em;\n  width: 34px;\n  flex-shrink: 0;\n  position: absolute;\n  right: 0;\n  top: 50%;\n  transform: translateY(-50%);\n  transition: transform 0.3s ease, color 0.3s ease;\n}\n\n.t4s-tab-wrapper.t4s-active .t4s-accor-title::after {\n  content: \"–\";\n  color: #000;\n}\n\n/* --- HIDE DEFAULT ICONS --- */\n.t4s-accor-icon,\n.t4s-accor-item-nav {\n  display: none !important;\n}\n\n/* --- CONTENT (ANSWER) --- */\n.t4s-tab-content {\n  display: none;\n  text-align: left !important;\n  border: none !important;\n  margin: 20px 0 0 0 !important;\n  padding: 0 !important;\n  font-size: 14px;\n  line-height: 1.7;\n  color: #222 !important;\n  background: none !important;\n}\n\n.t4s-tab-wrapper.t4s-active .t4s-tab-content {\n  display: block;\n}\n\n/* --- REMOVE INLINE DISPLAY OVERRIDES --- */\n.t4s-tab-content[style] {\n  display: none !important;\n}\n.t4s-tab-wrapper.t4s-active .t4s-tab-content[style] {\n  display: block !important;\n}\n\n/* --- UNIVERSAL LEFT RESET --- */\n.t4s-tabs.t4s-type-accordion,\n.t4s-tab-wrapper,\n.t4s-accor-title,\n.t4s-accor-text,\n.t4s-accor-text span,\n.t4s-accor-title span[itemprop=\"name\"] {\n  padding-left: 0 !important;\n  margin-left: 0 !important;\n  text-indent: 0 !important;\n}\n\n/* --- MOBILE FIXES --- */\n@media (max-width: 767px) {\n  .t4s-tabs.t4s-type-accordion,\n  .t4s-tab-wrapper,\n  .t4s-accor-title,\n  .t4s-tab-content {\n    padding-left: 0 !important;\n    margin-left: 0 !important;\n    text-align: left !important;\n  }\n\n  .t4s-tab-wrapper {\n    padding: 20px 0 !important; /* increased spacing between questions */\n  }\n\n  .t4s-accor-title {\n    font-size: 13.5px !important;\n    line-height: 1.8 !important;\n    padding: 14px 40px 14px 0;\n  }\n\n  .t4s-accor-text span,\n  .t4s-accor-title span[itemprop=\"name\"] {\n    line-height: 1.8 !important;\n  }\n\n  .t4s-accor-title::after {\n    font-size: 13px;\n    right: 0 !important;\n  }\n\n  .t4s-tab-content {\n    font-size: 14px;\n    margin: 8px 0 0 0 !important;\n    padding: 0 0 6px 0 !important;\n  }\n}\n/* --- MOBILE FIXES --- */\n@media (max-width: 767px) {\n  .t4s-tabs.t4s-type-accordion,\n  .t4s-tab-wrapper,\n  .t4s-accor-title,\n  .t4s-tab-content {\n    padding-left: 0 !important;\n    margin-left: 0 !important;\n    text-align: left !important;\n  }\n\n  /* Base spacing between questions */\n  .t4s-tab-wrapper {\n    padding: 18px 0 !important;\n  }\n\n  /* Remove bottom padding when open (so no extra gap below the answer) */\n  .t4s-tab-wrapper.t4s-active {\n    padding-bottom: 0 !important;\n  }\n\n  .t4s-accor-title {\n    font-size: 13.5px !important;\n    line-height: 1.8 !important;\n    padding: 14px 40px 14px 0;\n  }\n\n  .t4s-accor-text span,\n  .t4s-accor-title span[itemprop=\"name\"] {\n    line-height: 1.8 !important;\n  }\n\n  .t4s-accor-title::after {\n    font-size: 13px;\n    right: 0 !important;\n  }\n\n  .t4s-tab-content {\n    font-size: 14px;\n    margin: 20px 0 30px 0 !important;\n    padding: 0 !important; /* no extra space inside answer */\n  }\n}"
